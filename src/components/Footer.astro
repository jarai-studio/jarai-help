---
// ✦ Footer route split (§2.3 / §3.6):
//   • HOME (/)       → rich 4-column footer (HomeFooter).
//   • INTERIOR pages → Prev/Next pager + © line, rendered PIXEL-IDENTICAL to the dev
//     portal's Pager.astro / .docs-copyright (same markup + CSS, token-mapped) instead of
//     Starlight's default pager, so the two footers match exactly.
import type { Props } from '@astrojs/starlight/props';
import HomeFooter from './HomeFooter.astro';

const isHome = Astro.url.pathname.replace(/\/+$/, '') === '';
const { prev, next } = Astro.props.pagination ?? {};
---

{isHome ? (
  <HomeFooter />
) : (
  <Fragment>
    {(prev || next) && (
      <nav class="pager" aria-label="Previous and next page">
        {prev && (
          <a href={prev.href} rel="prev" class="pager-link pager-prev">
            <svg class="pager-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
            <span class="pager-meta">
              <span class="pager-label">Previous</span>
              <span class="pager-title">{prev.label}</span>
            </span>
          </a>
        )}
        {next && (
          <a href={next.href} rel="next" class="pager-link pager-next">
            <span class="pager-meta">
              <span class="pager-label">Next</span>
              <span class="pager-title">{next.label}</span>
            </span>
            <svg class="pager-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        )}
      </nav>
    )}
    <p class="jarai-copyright"><a href="/general/contact/">Contact us</a> · © 2026 JARAI STUDIO Ltd. All rights reserved.</p>
  </Fragment>
)}

<style>
  /* Pager — identical to the dev portal's Pager.astro (tokens mapped to Help's). */
  .pager {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }
  .pager-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    border: 1px solid var(--jarai-text-strong);   /* white box line; teal on hover (like the search) */
    border-radius: var(--radius-card);
    padding: var(--space-md);
    text-decoration: none;
    color: var(--jarai-text-muted);
    box-shadow: 0 1px 3px rgba(20, 20, 19, 0.06);
    overflow-wrap: anywhere;
    transition: border-color 0.15s ease;
  }
  .pager-link:hover {
    border-color: var(--color-accent-1);
  }
  .pager-next {
    justify-content: flex-end;
    text-align: end;
    flex-direction: row-reverse;
  }
  .pager-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pager-label {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--jarai-text-muted);
  }
  .pager-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--jarai-text-strong);
  }
  .pager-arrow {
    flex-shrink: 0;
    color: var(--jarai-text-muted);
  }

  /* © line — matches the dev portal's .docs-copyright text (body font, 0.8125rem, muted).
     The full-bleed masking band (position/width/margin/padding/bg/::before line) lives in
     starlight-overrides.css; only the text styling is set here. */
  .jarai-copyright {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--jarai-text-muted);
  }
</style>
