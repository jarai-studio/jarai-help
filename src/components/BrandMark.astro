---
// Consistent JARAI Studio brand block — logo mark + wordmark + tagline.
// Used on the Help site home page. Mirror of the Console LoginPage and Dev Portal hero.
---
<div class="jarai-brand-mark">
  <!-- ✦ Design System Phase 0.2 — aperture mark (inlined; currentColor + ember spark) replaces the legacy bloom mark. -->
  <svg class="jarai-mark" width="48" height="48" viewBox="0 0 100 100" fill="none" aria-hidden="true">
    <circle cx="50" cy="50" r="41" stroke="currentColor" stroke-width="2.6" opacity="0.5"></circle>
    <g stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M50 31 L66.45 40.5 L66.45 59.5 L50 69 L33.55 59.5 L33.55 40.5 Z"></path>
      <line x1="50" y1="31" x2="74.4" y2="20.9"></line>
      <line x1="66.45" y1="40.5" x2="87.4" y2="56.6"></line>
      <line x1="66.45" y1="59.5" x2="63" y2="85.7"></line>
      <line x1="50" y1="69" x2="25.6" y2="79.1"></line>
      <line x1="33.55" y1="59.5" x2="12.6" y2="43.4"></line>
      <line x1="33.55" y1="40.5" x2="37" y2="14.3"></line>
    </g>
    <circle cx="50" cy="50" r="5.5" fill="var(--color-spark, #E0823F)"></circle>
  </svg>
  <div class="jarai-brand-words">
    <span class="jarai-name">JARAI</span><span class="jarai-studio">STUDIO</span>
  </div>
  <p class="jarai-tagline">The Autonomous Media Engine</p>
</div>

<style>
  /* Closing brand band — matches the dev portal's .brand-band (centred mark, --space-2xl
     vertical padding, subtle top divider) so the two lockups are identical at the same
     flow position. */
  .jarai-brand-mark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-subtle);
  }
  .jarai-mark {
    color: var(--sl-color-accent);
  }
  .jarai-brand-words {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    line-height: 1;
  }
  .jarai-name {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jarai-text-strong);
  }
  .jarai-studio {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sl-color-accent);
  }
  .jarai-tagline {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-mid);
    margin: 0;
  }
</style>
